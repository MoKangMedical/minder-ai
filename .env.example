# ============================================================
# Minder AI红娘 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 应用基础配置
# ------------------------------------------------------------

# 应用名称
APP_NAME=Minder AI红娘

# 应用版本
APP_VERSION=1.0.0

# 运行环境: development / testing / production
APP_ENV=development

# 调试模式: true / false
DEBUG=true

# 服务端口
PORT=8000

# 服务主机
HOST=0.0.0.0

# ------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------

# 数据库连接URL
# SQLite: sqlite:///./minder.db
# PostgreSQL: postgresql://user:password@localhost:5432/minder
DATABASE_URL=sqlite:///./minder.db

# 数据库连接池大小（仅PostgreSQL）
DB_POOL_SIZE=10

# 数据库连接池最大溢出数
DB_MAX_OVERFLOW=20

# ------------------------------------------------------------
# Redis 配置
# ------------------------------------------------------------

# Redis连接URL
# 格式: redis://[:password@]host[:port][/database]
REDIS_URL=redis://localhost:6379/0

# Redis密码（如果设置了的话）
REDIS_PASSWORD=

# 缓存过期时间（秒）
CACHE_TTL=3600

# ------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------

# JWT密钥（务必修改！使用 openssl rand -hex 32 生成）
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT算法
JWT_ALGORITHM=HS256

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 刷新令牌过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS允许的源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------
# AI 服务配置
# ------------------------------------------------------------

# AI服务API密钥
AI_API_KEY=your-ai-api-key

# AI服务基础URL
AI_BASE_URL=https://api.openai.com/v1

# AI模型名称
AI_MODEL=gpt-4

# 声纹分析服务URL
VOICE_ANALYSIS_URL=http://localhost:8001/analyze

# 表情识别服务URL
FACE_ANALYSIS_URL=http://localhost:8002/analyze

# ------------------------------------------------------------
# 文件上传配置
# ------------------------------------------------------------

# 上传文件存储路径
UPLOAD_DIR=./uploads

# 头像最大大小（MB）
MAX_AVATAR_SIZE_MB=5

# 语音最大大小（MB）
MAX_VOICE_SIZE_MB=10

# 允许的图片格式
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,webp

# 允许的音频格式
ALLOWED_AUDIO_TYPES=mp3,wav,m4a

# ------------------------------------------------------------
# 支付配置
# ------------------------------------------------------------

# 支付平台: alipay / wechat
PAYMENT_PLATFORM=alipay

# 支付宝应用ID
ALIPAY_APP_ID=

# 支付宝私钥
ALIPAY_PRIVATE_KEY=

# 支付宝公钥
ALIPAY_PUBLIC_KEY=

# 微信支付商户号
WECHAT_MCH_ID=

# 微信支付API密钥
WECHAT_API_KEY=

# ------------------------------------------------------------
# 短信服务配置
# ------------------------------------------------------------

# 短信服务商: aliyun / tencent
SMS_PROVIDER=aliyun

# 阿里云短信AccessKey
ALIYUN_SMS_ACCESS_KEY=

# 阿里云短信AccessSecret
ALIYUN_SMS_ACCESS_SECRET=

# 阿里云短信签名
ALIYUN_SMS_SIGN_NAME=Minder

# 阿里云短信模板ID
ALIYUN_SMS_TEMPLATE_ID=

# ------------------------------------------------------------
# 邮件服务配置
# ------------------------------------------------------------

# SMTP服务器
SMTP_HOST=smtp.example.com

# SMTP端口
SMTP_PORT=587

# SMTP用户名
SMTP_USER=

# SMTP密码
SMTP_PASSWORD=

# 发件人邮箱
FROM_EMAIL=noreply@minder.ai

# 发件人名称
FROM_NAME=Minder AI红娘

# ------------------------------------------------------------
# 对象存储配置（可选）
# ------------------------------------------------------------

# 存储类型: local / oss / s3
STORAGE_TYPE=local

# OSS配置（阿里云）
OSS_ENDPOINT=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET_NAME=

# S3配置（AWS）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION=

# CDN域名
CDN_URL=https://cdn.minder.ai

# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------

# 日志级别: DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/minder.log

# 日志格式
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ------------------------------------------------------------
# 监控配置（可选）
# ------------------------------------------------------------

# Sentry DSN（错误追踪）
SENTRY_DSN=

# Prometheus指标端口
METRICS_PORT=9090

# ------------------------------------------------------------
# WebSocket 配置
# ------------------------------------------------------------

# WebSocket心跳间隔（秒）
WS_HEARTBEAT_INTERVAL=30

# WebSocket最大连接数
WS_MAX_CONNECTIONS=1000

# ------------------------------------------------------------
# 匹配算法配置
# ------------------------------------------------------------

# 每日推荐数量
DAILY_RECOMMENDATIONS=10

# 免费用户每日推荐限制
FREE_DAILY_LIMIT=5

# 超级喜欢每日限制
SUPER_LIKE_DAILY_LIMIT=3

# 匹配分数权重
WEIGHT_PERSONALITY=0.25
WEIGHT_VALUES=0.30
WEIGHT_LIFESTYLE=0.20
WEIGHT_HEALTH=0.15
WEIGHT_VOICE=0.05
WEIGHT_FACE=0.05

# ------------------------------------------------------------
# 开发工具配置（仅开发环境）
# ------------------------------------------------------------

# 是否启用热重载
RELOAD=true

# 是否启用API文档
DOCS_ENABLED=true

# 是否启用调试工具栏
DEBUG_TOOLBAR=false
